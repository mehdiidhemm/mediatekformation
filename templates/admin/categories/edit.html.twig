{% extends 'base.html.twig' %}

{% block title %}Admin - Modifier catégorie{% endblock %}

{% block body %}
<div class="mt-4 mb-3">
    <h1>Modifier la catégorie</h1>
</div>

<div class="card">
    <div class="card-body">
        {{ form_start(form) }}
            {{ form_row(form.name) }}

            <div class="mt-3">
                <button type="submit" class="btn btn-warning">Modifier</button>
                <a href="{{ path('admin_categories') }}" class="btn btn-secondary">Retour</a>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
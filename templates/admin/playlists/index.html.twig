{% extends 'admin/base_admin.html.twig' %}

{% block title %}Admin - Catégories{% endblock %}
{% block admin_title %}Gestion des catégories{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mt-4 mb-3">
    <h1 class="m-0">Gestion des playlists</h1>
    <div class="d-flex gap-2">
        <a href="{{ path('admin_playlists_add') }}" class="btn btn-primary">Ajouter une playlist</a>
        {% if app.user %}
            <a href="{{ path('app_logout') }}" class="btn btn-outline-danger">Déconnexion</a>
        {% endif %}
    </div>
</div>

{% for message in app.flashes('success') %}
    <div class="alert alert-success">{{ message }}</div>
{% endfor %}
{% for message in app.flashes('danger') %}
    <div class="alert alert-danger">{{ message }}</div>
{% endfor %}

<table class="table table-bordered table-striped align-middle">
    <thead>
        <tr>
            <th style="width: 80px;">ID</th>
            <th>Nom</th>
            <th style="width: 260px;">Actions</th>
        </tr>
    </thead>
    <tbody>
    {% for playlist in playlists %}
        <tr>
            <td>{{ playlist.id }}</td>
            <td>
                {# adapte selon ton champ : name ou nom #}
                {{ attribute(playlist, 'name') is defined ? playlist.name : (attribute(playlist, 'nom') is defined ? playlist.nom : 'Champ à vérifier') }}
            </td>
            <td>
                <a href="{{ path('admin_playlists_edit', {id: playlist.id}) }}" class="btn btn-sm btn-warning">
                    Modifier
                </a>

                <form method="post"
                      action="{{ path('admin_playlists_delete', {id: playlist.id}) }}"
                      style="display:inline-block;"
                      onsubmit="return confirm('Supprimer cette playlist ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_playlist_' ~ playlist.id) }}">
                    <button class="btn btn-sm btn-danger" type="submit">Supprimer</button>
                </form>
            </td>
        </tr>
    {% else %}
        <tr>
            <td colspan="3" class="text-center">Aucune playlist trouvée.</td>
        </tr>
    {% endfor %}
    </tbody>
</table>
{% endblock %}